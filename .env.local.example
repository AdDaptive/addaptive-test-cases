# Copy this file to .env.local for local VS Code Playwright runs.

# Select the named environment file to layer on top of .env.
# Allowed examples in this repo: dev, dev2, dev3, dev4, ali, design
ADDAPTIVE_ENV=ali

# Order Entry examples
ADDAPTIVE_ORDER_ENTRY_DB_OBJECT_ID=
ADDAPTIVE_ORDER_ENTRY_DB_RANGE=
ADDAPTIVE_ORDER_ENTRY_AD_SERVER=
ADDAPTIVE_ORDER_ENTRY_ACTION=

# Audience examples
ADDAPTIVE_AUDIENCE_DB_ID=

# Insight Studio examples
ADDAPTIVE_INSIGHT_DB_ID=

# Client Settings examples
ADDAPTIVE_CLIENT_SETTINGS_DB_ID=

# Optional auth overrides
ADDAPTIVE_LOGIN_USER_OVERRIDE=
ADDAPTIVE_LOGIN_PASSWORD_OVERRIDE=
ADDAPTIVE_IMPERSONATE_USER_OVERRIDE=

# Optional local DB override
ADDAPTIVE_DB_HOST=127.0.0.1
ADDAPTIVE_DB_PORT=5432
ADDAPTIVE_DB_NAME=addaptive_test_cases
ADDAPTIVE_DB_USER=addaptive_local
ADDAPTIVE_DB_PASSWORD=addaptive_local
